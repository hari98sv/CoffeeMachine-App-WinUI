<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CoffeeMachine.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CoffeeMachine.UI"
    xmlns:viewmodels="using:CoffeeMachine.UI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="Coffee Machine Kiosk">

    <Grid x:Name="Root">      
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" MaxWidth="1000">

                <!-- Header -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,40">
                    <TextBlock Text="☕" FontSize="60" Margin="0,0,20,0" Foreground="{StaticResource Gold}"/>
                    <TextBlock Text="COFFEE MACHINE KIOSK" Style="{StaticResource KioskHeaderStyle}"/>
                    <TextBlock Text="☕" FontSize="60" Margin="20,0,0,0" Foreground="{StaticResource Gold}"/>
                </StackPanel>

                <!-- Main Content Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column - Beverage Selection -->
                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="20">
                        <Border Style="{StaticResource KioskCardStyle}">
                            <StackPanel>
                                <TextBlock Text="SELECT YOUR BEVERAGE" FontSize="24" FontWeight="Bold" 
                                           Foreground="{StaticResource TextColorBrush}" Margin="0,0,0,20"/>

                                <ComboBox ItemsSource="{Binding AvailableBeverages}"
                                          DisplayMemberPath="Name"
                                          SelectedItem="{Binding SelectedBeverage, Mode=TwoWay}"
                                          Style="{StaticResource KioskComboBoxStyle}"
                                          IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="FontSize" Value="18"/>
                                            <Setter Property="Padding" Value="15"/>
                                            <Setter Property="Height" Value="50"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>

                                <TextBlock Text="SIZE" FontSize="18" FontWeight="Bold" 
                                           Foreground="{StaticResource TextColorBrush}" Margin="0,20,0,10"/>

                                <ComboBox ItemsSource="{Binding AvailableSizes}"
                                          SelectedItem="{Binding SelectedSize, Mode=TwoWay}"
                                          Style="{StaticResource KioskComboBoxStyle}"
                                          IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="FontSize" Value="18"/>
                                            <Setter Property="Padding" Value="15"/>
                                            <Setter Property="Height" Value="50"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Customization Options -->
                        <Border Style="{StaticResource KioskCardStyle}" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="CUSTOMIZE YOUR DRINK" FontSize="24" FontWeight="Bold" 
                                           Foreground="{StaticResource TextColorBrush}" Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <controls:ToggleSwitch Header="Sugar"
                                                           IsOn="{Binding AddSugar, Mode=TwoWay}"
                                                           Style="{StaticResource KioskToggleSwitchStyle}"
                                                           IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                                                           Margin="0,0,20,0"/>

                                    <controls:ToggleSwitch Header="Milk"
                                                           IsOn="{Binding AddMilk, Mode=TwoWay}"
                                                           Style="{StaticResource KioskToggleSwitchStyle}"
                                                           IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right Column - Customer Info & Actions -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="20">
                        <Border Style="{StaticResource KioskCardStyle}">
                            <StackPanel>
                                <TextBlock Text="CUSTOMER INFORMATION" FontSize="24" FontWeight="Bold" 
                                           Foreground="{StaticResource TextColorBrush}" Margin="0,0,0,20"/>

                                <TextBox Text="{Binding CustomerName, Mode=TwoWay}"
                                         PlaceholderText="ENTER YOUR NAME"
                                         Style="{StaticResource KioskTextBoxStyle}"
                                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

                                <TextBlock Text="SPECIAL INSTRUCTIONS" FontSize="18" FontWeight="Bold" 
                                           Foreground="{StaticResource TextColorBrush}" Margin="0,20,0,10"/>

                                <TextBox AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                                         PlaceholderText="Any special requests..."
                                         Style="{StaticResource KioskTextBoxStyle}"
                                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                            <Button Content="🔄 REFRESH" Command="{Binding RefreshCommand}"
                                    Style="{StaticResource KioskButtonStyle}"
                                    Background="{StaticResource LightTextBrush}"
                                    BorderBrush="{StaticResource SecondaryButtonBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource TextColorBrush}"/>

                            <Button Content="✅ ORDER NOW" Command="{Binding OrderCommand}"
                                    Style="{StaticResource KioskButtonStyle}"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Status Area -->
                <Border Background="{StaticResource LightTextBrush}" BorderThickness="1" BorderBrush="{StaticResource DarkSlate}" CornerRadius="16" Margin="20" Padding="20">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="Order Status" FontSize="24" FontWeight="Bold" 
                                   Foreground="{StaticResource Gold}" Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource KioskStatusStyle}"
                                   Foreground="{Binding StatusMessage, Converter={StaticResource StatusColorConverter}}"/>

                        <!-- Progress Indicator -->
                        <!--<StackPanel Orientation="Vertical" HorizontalAlignment="Center" 
                                   Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,20,0,0">
                            <ProgressRing IsActive="{Binding IsProcessing}" Width="80" Height="80"
                                         Foreground="{StaticResource Gold}" Margin="0,0,0,10"/>
                            <TextBlock Text="Preparing your delicious coffee..." 
                                       Foreground="{StaticResource LightCoffee}"
                                       FontSize="18" TextAlignment="Center"/>
                        </StackPanel>-->
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,20">
                    <TextBlock Text="🌰 🫘 ☕ 🍵 🥛 🧊" FontSize="24" Foreground="{StaticResource LightCoffee}"/>
                    <TextBlock Text="  Enjoy your coffee!  " FontSize="16" Foreground="{StaticResource LightTextBrush}" 
                               VerticalAlignment="Center" Margin="20,0"/>
                    <TextBlock Text="☕ 🥛 🧊 🍵 🫘 🌰" FontSize="24" Foreground="{StaticResource LightCoffee}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>